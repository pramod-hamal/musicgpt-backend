        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "let url = pm.variables.get('url');",
          "const uri = pm.request.url.toString().replace(/^\\/|\\/$/g, '');",
          "pm.request.url = url.toString().replace(/^\\/|\\/$/g, '') + \"/\" + uri;",
          "",
          "let token = pm.variables.get(\"token\");",
          "",
          "pm.request.addHeader({ \"key\": \"Authorization\", \"value\": \"Bearer \" + token })",
          "",
          "pm.request.addHeader({ \"key\": \"Content-Type\", \"value\": \"Application/json\" })",
          ""
        ]
